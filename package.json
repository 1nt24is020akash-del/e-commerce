{
  "name": "ecommerce-mern",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run start --prefix backend",
    "server": "npm run dev --prefix backend",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm install --prefix backend --legacy-peer-deps && npm install --prefix frontend --legacy-peer-deps && npm run build --prefix frontend"
  },
  "dependencies": {
    "concurrently": "^8.2.1",
    "socket.io": "^4.8.3"
  }
}
